rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, write: if request.auth != null && request.auth.token.email == 'oilshakal@gmail.com';
    }

    // Bookings collection
    match /bookings/{bookingId} {
      allow create: if true; // Anyone can book
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        request.auth.token.email == 'oilshakal@gmail.com'
      );
      allow update, delete: if request.auth != null &&
        request.auth.token.email == 'oilshakal@gmail.com';
    }

    // Messages collection
    match /messages/{msgId} {
      allow create: if true; // Anyone can send a message
      allow read, update, delete: if request.auth != null &&
        request.auth.token.email == 'oilshakal@gmail.com';
    }

    // Discounts collection
    match /discounts/{discountId} {
      allow read: if true; // All users can see discounts
      allow write: if request.auth != null &&
        request.auth.token.email == 'oilshakal@gmail.com';
    }
  }
}
